{
  "Comment": "Monthly ML Model Training Pipeline - Trains new model with historical data",
  "StartAt": "GenerateTimestamp",
  "States": {
    "GenerateTimestamp": {
      "Type": "Pass",
      "Parameters": {
        "season.$": "$.season",
        "timestamp.$": "States.Format('{}', $$.Execution.StartTime)"
      },
      "Next": "FeatureEngineering"
    },
    "FeatureEngineering": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sagemaker:createProcessingJob.sync",
      "Parameters": {
        "ProcessingJobName.$": "States.Format('feature-eng-{}', $.timestamp)",
        "RoleArn": "${sagemaker_role_arn}",
        "ProcessingInputs": [
          {
            "InputName": "code",
            "S3Input": {
              "S3Uri": "s3://${data_bucket}/ml/code/feature_engineering.py",
              "LocalPath": "/opt/ml/processing/input/code",
              "S3DataType": "S3Prefix",
              "S3InputMode": "File"
            }
          }
        ],
        "ProcessingOutputConfig": {
          "Outputs": [
            {
              "OutputName": "features",
              "S3Output": {
                "S3Uri.$": "States.Format('s3://${data_bucket}/ml/features/{}/', $.season)",
                "LocalPath": "/opt/ml/processing/output",
                "S3UploadMode": "EndOfJob"
              }
            }
          ]
        },
        "AppSpecification": {
          "ImageUri": "763104351884.dkr.ecr.us-east-1.amazonaws.com/sagemaker-scikit-learn:1.0-1-cpu-py3",
          "ContainerEntrypoint": [
            "python3",
            "/opt/ml/processing/input/code/feature_engineering.py",
            "--mode",
            "train",
            "--output-path",
            "/opt/ml/processing/output/features.csv"
          ]
        },
        "ProcessingResources": {
          "ClusterConfig": {
            "InstanceCount": 1,
            "InstanceType": "ml.m5.xlarge",
            "VolumeSizeInGB": 30
          }
        },
        "NetworkConfig": {
          "VpcConfig": {
            "SecurityGroupIds": ["${rds_security_group_id}"],
            "Subnets": ${private_subnet_ids}
          }
        },
        "Environment": {
          "DB_SECRET_ARN": "${db_secret_arn}",
          "SEASONS_BEFORE.$": "$.season"
        }
      },
      "ResultPath": "$.featureEngineeringResult",
      "ResultSelector": {
        "ProcessingJobName.$": "$.ProcessingJobName",
        "ProcessingJobArn.$": "$.ProcessingJobArn"
      },
      "Next": "ModelTraining",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.error",
          "Next": "TrainingFailed"
        }
      ]
    },
    "ModelTraining": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sagemaker:createTrainingJob.sync",
      "Parameters": {
        "TrainingJobName.$": "States.Format('train-{}', $.timestamp)",
        "RoleArn": "${sagemaker_role_arn}",
        "AlgorithmSpecification": {
          "TrainingImage": "763104351884.dkr.ecr.us-east-1.amazonaws.com/sagemaker-scikit-learn:1.0-1-cpu-py3",
          "TrainingInputMode": "File",
          "EnableSageMakerMetricsTimeSeries": true
        },
        "InputDataConfig": [
          {
            "ChannelName": "training",
            "DataSource": {
              "S3DataSource": {
                "S3DataType": "S3Prefix",
                "S3Uri.$": "States.Format('s3://${data_bucket}/ml/features/{}/features.csv', $.season)",
                "S3DataDistributionType": "FullyReplicated"
              }
            },
            "ContentType": "text/csv"
          }
        ],
        "OutputDataConfig": {
          "S3OutputPath.$": "States.Format('s3://${data_bucket}/ml/models/{}/', $.season)"
        },
        "ResourceConfig": {
          "InstanceType": "ml.m5.xlarge",
          "InstanceCount": 1,
          "VolumeSizeInGB": 30
        },
        "StoppingCondition": {
          "MaxRuntimeInSeconds": 3600
        },
        "HyperParameters": {
          "n_estimators": "200",
          "max_depth": "20",
          "min_samples_split": "5",
          "min_samples_leaf": "2",
          "random_state": "42"
        }
      },
      "ResultPath": "$.modelTrainingResult",
      "ResultSelector": {
        "TrainingJobName.$": "$.TrainingJobName",
        "TrainingJobArn.$": "$.TrainingJobArn",
        "ModelArtifacts.$": "$.ModelArtifacts"
      },
      "Next": "TrainingSuccess",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.error",
          "Next": "TrainingFailed"
        }
      ]
    },
    "TrainingSuccess": {
      "Type": "Pass",
      "Result": {
        "status": "SUCCESS",
        "message": "Model training completed successfully"
      },
      "End": true
    },
    "TrainingFailed": {
      "Type": "Pass",
      "Result": {
        "status": "FAILED",
        "message": "Model training pipeline failed"
      },
      "End": true
    }
  }
}
